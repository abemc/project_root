[Unit]
Description=Project Analyzer Collector
After=network.target
StartLimitIntervalSec=600
StartLimitBurst=10

[Service]
Type=simple
WorkingDirectory=/home/abemc/project_root
EnvironmentFile=-/etc/project_analyzer/collector.env
ExecStart=/bin/sh /home/abemc/project_root/deploy/collector-start.sh
Restart=on-failure
RestartSec=30
StandardOutput=journal
StandardError=journal
SyslogIdentifier=project-analyzer-collector

[Install]
WantedBy=multi-user.target
