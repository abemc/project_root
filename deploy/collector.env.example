## Example environment file for Collector systemd unit
# Copy to /etc/project_analyzer/collector.env and edit values, then `systemctl daemon-reload`.

# Shared secret used by clients to POST usage entries
COLLECTOR_SECRET=change_me

# Paths for TLS certificate and key (optional). If absent, start without TLS.
CERTFILE=/etc/project_analyzer/cert.pem
KEYFILE=/etc/project_analyzer/key.pem

# Path to the central log file
LOG_PATH=/var/log/project_analyzer/central.log
