# 本番環境設定ファイル - .env.production
# このファイルは本番環境でのデプロイメント時に使用します

# ============================================================
# アプリケーション基本設定
# ============================================================

# 環境指定
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# バージョン
APP_VERSION=1.0.0
APP_NAME=RAG Agent with Phase 5 Learning Systems

# ============================================================
# Python/Streamlit 設定
# ============================================================

# Python 設定
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Streamlit 設定
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_LOGGER_LEVEL=info
STREAMLIT_CLIENT_SHOW_ERROR_DETAILS=false
STREAMLIT_SERVER_ENABLE_XSRF_PROTECTION=true

# ============================================================
# RAG Agent 設定
# ============================================================

# キャッシュ設定
RAG_CACHE_MAX_SIZE=1000
RAG_CACHE_TTL=3600

# バッチ処理設定
RAG_BATCH_SIZE=50
RAG_BATCH_TIMEOUT=5

# パス設定
RAG_CONFIG_PATH=/app/config/config.json
RAG_CHECKPOINT_DIR=/app/checkpoints
RAG_CORPUS_DIR=/app/corpus
RAG_LOG_DIR=/app/logs

# ============================================================
# LLM 設定 (Ollama)
# ============================================================

# Ollama ホスト
OLLAMA_HOST=http://ollama:11434

# LLM モデル
LLM_MODEL=qwen2.5
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_TOP_P=0.9
LLM_TOP_K=40

# LLM タイムアウト
LLM_TIMEOUT=30

# ============================================================
# ベクトル/エンベッディング設定 (FAISS + BGE)
# ============================================================

# FAISS インデックス
FAISS_INDEX_PATH=/app/corpus
FAISS_INDEX_TYPE=HNSW
FAISS_METRIC_TYPE=IP

# エンベッディング設定
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_LENGTH=512

# ============================================================
# メモリ管理 (Phase 5) 設定
# ============================================================

# Meta Memory
META_MEMORY_MAX_SIZE=5000
META_MEMORY_QUALITY_THRESHOLD=0.5
META_MEMORY_RECENCY_WEIGHT=0.3

# Procedural Memory
PROC_MEMORY_MAX_PROCEDURES=1000
PROC_MEMORY_MIN_RELIABILITY=0.6

# Context Retrieval
CONTEXT_RETRIEVAL_TOP_K=5
CONTEXT_RETRIEVAL_SIMILARITY_THRESHOLD=0.6

# Transfer Learning
TRANSFER_LEARNING_SIMILARITY_THRESHOLD=0.7
TRANSFER_LEARNING_MAX_ATTEMPTS=3

# Reinforcement Learning
RL_LEARNING_RATE=0.01
RL_DISCOUNT_FACTOR=0.99
RL_EXPLORATION_RATE=0.1

# Adaptive Forgetting
ADAPTIVE_FORGETTING_RETENTION_DAYS=30
ADAPTIVE_FORGETTING_MIN_ACCESS_COUNT=3

# ============================================================
# 監視・ロギング設定
# ============================================================

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_RETENTION_TIME=30d

# Grafana
GRAFANA_ENABLED=true
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=secure_password_change_me

# ログ設定
LOG_FORMAT=json
LOG_FILE=/app/logs/app.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ============================================================
# セキュリティ設定
# ============================================================

# HTTPS
ENABLE_HTTPS=false
SSL_CERT_PATH=/app/certs/cert.pem
SSL_KEY_PATH=/app/certs/key.pem

# CORS
CORS_ALLOWED_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# API キー (本番環境では環境変数に設定)
API_KEY_ENABLED=true
# API_KEY=your_secret_key_here

# レート制限
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ============================================================
# データベース設定 (オプション・将来対応)
# ============================================================

# PostgreSQL (オプション)
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=rag_agent
# DB_USER=rag_user
# DB_PASSWORD=secure_password

# MongoDB (オプション)
# MONGODB_URI=mongodb://mongodb:27017
# MONGODB_DB=rag_agent

# ============================================================
# Redis キャッシング設定 (オプション)
# ============================================================

REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# ============================================================
# リソース制限設定
# ============================================================

# CPU
CPU_LIMIT=2
CPU_RESERVATION=1

# メモリ
MEMORY_LIMIT=1024  # MB
MEMORY_RESERVATION=512  # MB
MEMORY_WARNING_THRESHOLD=80  # %

# タイムアウト
REQUEST_TIMEOUT=30
LLM_REQUEST_TIMEOUT=60
BATCH_PROCESSING_TIMEOUT=300

# ============================================================
# デプロイメント設定
# ============================================================

# ローリングデプロイメント
DEPLOYMENT_STRATEGY=rolling
DEPLOYMENT_GRACE_PERIOD=30

# ヘルスチェック
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# ============================================================
# 通知設定
# ============================================================

# Slack (オプション)
SLACK_ENABLED=false
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_CHANNEL=#deployments

# メール (オプション)
EMAIL_ENABLED=false
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_FROM=rag-agent@company.com

# ============================================================
# デバッグ/トラブルシューティング設定
# ============================================================

# パフォーマンス プロファイリング
ENABLE_PROFILING=false

# トレーシング
ENABLE_TRACING=true
TRACE_SAMPLE_RATE=0.1

# ドライラン
DRY_RUN=false

# ============================================================
# 本番環境チェックリスト
# ============================================================

# このファイルを使用する前に、以下を確認してください:

# [ ] APP_ENV が "production" に設定されている
# [ ] DEBUG が "false" に設定されている
# [ ] API_KEY が設定されている (有効な場合)
# [ ] DB_PASSWORD が変更されている (データベース使用時)
# [ ] SLACK_WEBHOOK_URL が設定されている (Slack通知時)
# [ ] SSL 証明書がインストールされている (HTTPS有効時)
# [ ] ログディレクトリが存在し、書き込み可能
# [ ] チェックポイントディレクトリが存在し、書き込み可能

# 本番環境への展開:
# docker-compose -f docker-compose.production.yml --env-file .env.production up -d
