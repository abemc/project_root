    "try:\n",
    "    from transformers import BertTokenizer\n",
    "    \n",
    "    class BertWordPieceTokenizer:\n",
    "        \"\"\"BERT の WordPiece トークナイザー\"\"\"\n",
    "        \n",
    "        def __init__(self, model_name='bert-base-multilingual-cased'):\n",
    "            self.tokenizer = BertTokenizer.from_pretrained(model_name)\n",
    "        \n",
    "        def tokenize(self, text):\n",
    "            \"\"\"トークン化\"\"\"\n",
    "            tokens = self.tokenizer.tokenize(text)\n",
    "            return tokens\n",
    "        \n",
    "        def get_token_ids(self, text):\n",
    "            \"\"\"トークンID化\"\"\"\n",
    "            token_ids = self.tokenizer.encode(text)\n",
    "            return token_ids\n",
    "    \n",
    "    # 使用例\n",
    "    bert_tokenizer = BertWordPieceTokenizer()\n",
    "    \n",
    "    print(\"BERT WordPiece トークン化の例：\")\n",
    "    print(\"=\" * 70)\n",
    "    \n",
    "    test_texts = [\n",
    "        \"unbelievable\",\n",
    "        \"I love NLP\"\n",
    "    ]\n",
    "    \n",
    "    for text in test_texts:\n",
    "        tokens = bert_tokenizer.tokenize(text)\n",
    "        token_ids = bert_tokenizer.get_token_ids(text)\n",
    "        \n",
    "        print(f\"入力: {text}\")\n",
    "        print(f\"トークン: {tokens}\")\n",
    "        print(f\"トークンID: {token_ids}\")\n",
    "        print()\n",
    "        \n",
    "except ImportError:\n",
    "    print(\"⚠︎ Transformersライブラリがインストールされていません\")\n",
    "    print(\"インストール: pip install transformers\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "6409745f",
   "metadata": {},
   "source": [
    "## セクション4: バッチ処理とパディング"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c1418e7c",
   "metadata": {},
   "source": [
    "## セクション4: 語彙（Vocabulary）の構築とトークンID変換\n",
    "\n",
    "語彙辞書の構築とトークンからIDへの変換"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 34,
   "id": "16be0259",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "語彙の構築：\n",
      "======================================================================\n",
      "語彙サイズ: 18\n",
      "word2id (一部): {'<PAD>': 0, '<UNK>': 1, '<START>': 2, '<END>': 3, 'は': 4, '学習': 5, '自然': 6, '言語': 7, '処理': 8, '機械': 9}\n",
      "\n",
      "トークン: ['自然', '言語', '処理', '未知語']\n",
      "ID: [6, 7, 8, 1]\n",
      "\n",
      "復元トークン: ['自然', '言語', '処理', '<UNK>']\n"
     ]
    }
   ],
   "source": [
    "class Vocabulary:\n",
    "    \"\"\"単語から ID へのマッピング\"\"\"\n",
    "    \n",
    "    def __init__(self, min_freq=1):\n",
    "        self.word2id = {}\n",
    "        self.id2word = {}\n",
    "        self.min_freq = min_freq\n",
    "        self._add_special_tokens()\n",
    "    \n",
    "    def _add_special_tokens(self):\n",
    "        \"\"\"特殊トークンを追加\"\"\"\n",
    "        special_tokens = ['<PAD>', '<UNK>', '<START>', '<END>']\n",
    "        for token in special_tokens:\n",
    "            idx = len(self.word2id)\n",
    "            self.word2id[token] = idx\n",
    "            self.id2word[idx] = token\n",
    "    \n",
    "    def build_from_texts(self, texts, max_vocab_size=10000):\n",
    "        \"\"\"\n",
    "        テキストコーパスから語彙を構築\n",
    "        \n",
    "        Args:\n",
    "            texts: トークンのリストのリスト\n",
    "            max_vocab_size: 最大語彙サイズ\n",
    "        \"\"\"\n",
    "        # 単語の出現頻度をカウント\n",
    "        word_freq = {}\n",
    "        for tokens in texts:\n",
    "            for token in tokens:\n",
    "                word_freq[token] = word_freq.get(token, 0) + 1\n",
    "        \n",
    "        # 頻度でフィルタ\n",
    "        filtered_words = [\n",
    "            w for w, f in word_freq.items() \n",
    "            if f >= self.min_freq\n",
    "        ]\n",
    "        \n",
    "        # 頻度でソート（多い順）\n",
    "        sorted_words = sorted(\n",
    "            filtered_words, \n",
    "            key=lambda w: word_freq[w], \n",
    "            reverse=True\n",
    "        )\n",
    "        \n",
    "        # 語彙に追加（最大サイズまで）\n",
    "        for word in sorted_words[:max_vocab_size]:\n",
    "            if word not in self.word2id:\n",
    "                idx = len(self.word2id)\n",
    "                self.word2id[word] = idx\n",
    "                self.id2word[idx] = word\n",
    "    \n",
    "    def encode(self, tokens):\n",
    "        \"\"\"トークンをIDに変換\"\"\"\n",
    "        ids = []\n",
    "        for token in tokens:\n",
    "            if token in self.word2id:\n",
    "                ids.append(self.word2id[token])\n",
    "            else:\n",
    "                ids.append(self.word2id['<UNK>'])  # 未知語\n",
    "        return ids\n",
    "    \n",
    "    def decode(self, ids):\n",
    "        \"\"\"IDをトークンに戻す\"\"\"\n",
    "        tokens = []\n",
    "        for idx in ids:\n",
    "            if idx in self.id2word:\n",
    "                tokens.append(self.id2word[idx])\n",
    "            else:\n",
    "                tokens.append('<UNK>')\n",
    "        return tokens\n",
    "    \n",
    "    def __len__(self):\n",
    "        return len(self.word2id)\n",
    "\n",
    "# 使用例\n",
    "vocab = Vocabulary(min_freq=1)\n",
    "\n",
    "# サンプルテキストからトークンのリストを作成\n",
    "sample_token_lists = [\n",
    "    ['自然', '言語', '処理', 'は', '難しい'],\n",
    "    ['機械', '学習', 'は', '面白い'],\n",
    "    ['深層', '学習', 'は', '強力', 'だ'],\n",
    "    ['自然', '言語', '処理', 'と', '機械', '学習', 'は', '関連', 'がある']\n",
    "]\n",
    "\n",
    "vocab.build_from_texts(sample_token_lists, max_vocab_size=100)\n",
    "\n",
    "print(\"語彙の構築：\")\n",
    "print(\"=\" * 70)\n",
    "print(f\"語彙サイズ: {len(vocab)}\")\n",
    "print(f\"word2id (一部): {dict(list(vocab.word2id.items())[:10])}\")\n",
    "print()\n",
    "\n",
    "# トークン → ID\n",
    "test_tokens = ['自然', '言語', '処理', '未知語']\n",
    "token_ids = vocab.encode(test_tokens)\n",
    "print(f\"トークン: {test_tokens}\")\n",
    "print(f\"ID: {token_ids}\")\n",
    "print()\n",
    "\n",
    "# ID → トークン\n",
    "recovered_tokens = vocab.decode(token_ids)\n",
    "print(f\"復元トークン: {recovered_tokens}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c05733f9",
   "metadata": {},
   "source": [
    "## セクション5: バッチ処理とパディング"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "25728736",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "バッチ処理とパディング：\n",
      "======================================================================\n",
      "パディング後のID:\n",
      "[[ 6  7  8  0  0]\n",
      " [ 9  5  4 11  0]\n",
      " [12  5  0  0  0]]\n",
      "\n",
      "Attention マスク:\n",
      "[[1 1 1 0 0]\n",
      " [1 1 1 1 0]\n",
      " [1 1 0 0 0]]\n"
     ]
    }
   ],
   "source": [
    "# 注: numpy(np)はセクション1でインポート済みです\n",
    "# np.full()と np.int32 を使用します\n",
    "\n",
    "class BatchProcessor:\n",
    "    \"\"\"バッチ処理とパディング\"\"\"\n",
    "    \n",
    "    def __init__(self, vocab, pad_token='<PAD>'):\n",
    "        self.vocab = vocab\n",
    "        self.pad_idx = vocab.word2id[pad_token]\n",
    "    \n",
    "    def encode_texts(self, texts, max_length=None):\n",
    "        \"\"\"\n",
    "        複数テキストをエンコード＋パディング\n",
    "        \"\"\"\n",
    "        encoded = [self.vocab.encode(tokens) for tokens in texts]\n",
    "        \n",
    "        if max_length is None:\n",
    "            max_length = max(len(ids) for ids in encoded)\n",
    "        \n",
    "        padded = np.full((len(encoded), max_length), self.pad_idx, dtype=np.int32)\n",
    "        \n",
    "        for i, ids in enumerate(encoded):\n",
    "            length = min(len(ids), max_length)\n",
    "            padded[i, :length] = ids[:length]\n",
    "        \n",
    "        return padded\n",
    "    \n",
    "    def create_attention_mask(self, padded_ids):\n",
    "        \"\"\"Attention マスク\"\"\"\n",
    "        mask = (padded_ids != self.pad_idx).astype(np.int32)\n",
    "        return mask\n",
    "\n",
    "# 使用例\n",
    "processor = BatchProcessor(vocab, pad_token='<PAD>')\n",
    "\n",
    "batch_texts = [\n",
    "    ['自然', '言語', '処理'],\n",
    "    ['機械', '学習', 'は', '面白い'],\n",
    "    ['深層', '学習']\n",
    "]\n",
    "\n",
    "# エンコード\n",
    "padded_ids = processor.encode_texts(batch_texts, max_length=5)\n",
    "attention_mask = processor.create_attention_mask(padded_ids)\n",
    "\n",
    "print(\"バッチ処理とパディング：\")\n",
    "print(\"=\" * 70)\n",
    "print(\"パディング後のID:\")\n",
    "print(padded_ids)\n",
    "print()\n",
    "print(\"Attention マスク:\")\n",
    "print(attention_mask)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 42,
   "id": "0c70a0bc",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "バッチ処理とパディング：\n",
      "======================================================================\n",
      "パディング後のID:\n",
      "[[ 6  7  8  0  0]\n",
      " [ 9  5  4 11  0]\n",
      " [12  5  0  0  0]]\n",
      "\n",
      "Attention マスク:\n",
      "[[1 1 1 0 0]\n",
      " [1 1 1 1 0]\n",
      " [1 1 0 0 0]]\n"
     ]
    }
   ],
   "source": [
    "class BatchProcessor:\n",
    "    \"\"\"バッチ処理とパディング\"\"\"\n",
    "    \n",
    "    def __init__(self, vocab, pad_token='<PAD>'):\n",
    "        self.vocab = vocab\n",
    "        self.pad_idx = vocab.word2id[pad_token]\n",
    "    \n",
    "    def encode_texts(self, texts, max_length=None):\n",
    "        \"\"\"\n",
    "        複数テキストをエンコード＋パディング\n",
    "        \n",
    "        Args:\n",
    "            texts: トークンのリストのリスト\n",
    "            max_length: パディングの目標長（Noneで自動）\n",
    "        \n",
    "        Returns:\n",
    "            numpy配列 (batch_size, max_length)\n",
    "        \"\"\"\n",
    "        # トークンをIDに変換\n",
    "        encoded = [self.vocab.encode(tokens) for tokens in texts]\n",
    "        \n",
    "        # 最大長を決定\n",
    "        if max_length is None:\n",
    "            max_length = max(len(ids) for ids in encoded)\n",
    "        \n",
    "        # パディング\n",
    "        padded = np.full((len(encoded), max_length), self.pad_idx, dtype=np.int32)\n",
    "        \n",
    "        for i, ids in enumerate(encoded):\n",
    "            length = min(len(ids), max_length)\n",
    "            padded[i, :length] = ids[:length]\n",
    "        \n",
    "        return padded\n",
    "    \n",
    "    def create_attention_mask(self, padded_ids):\n",
    "        \"\"\"\n",
    "        Attention マスク（実際のトークンは1、パディングは0）\n",
    "        \"\"\"\n",
    "        mask = (padded_ids != self.pad_idx).astype(np.int32)\n",
    "        return mask\n",
    "\n",
    "# 使用例\n",
    "processor = BatchProcessor(vocab, pad_token='<PAD>')\n",
    "\n",
    "batch_texts = [\n",
    "    ['自然', '言語', '処理'],\n",
    "    ['機械', '学習', 'は', '面白い'],\n",
    "    ['深層', '学習']\n",
    "]\n",
    "\n",
    "# エンコード\n",
    "padded_ids = processor.encode_texts(batch_texts, max_length=5)\n",
    "attention_mask = processor.create_attention_mask(padded_ids)\n",
    "\n",
    "print(\"バッチ処理とパディング：\")\n",
    "print(\"=\" * 70)\n",
    "print(\"パディング後のID:\")\n",
    "print(padded_ids)\n",
    "print()\n",
    "print(\"Attention マスク:\")\n",
    "print(attention_mask)"
   ]
  },
