   "source": [
    "## セクション8: 完全な実装パイプライン\n",
    "\n",
    "テキスト入力から埋め込みベクトルまでの完全統合パイプライン"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b7a0747c",
   "metadata": {},
   "source": [
    "## セクション7: シーケンス統合（プーリング）\n",
    "\n",
    "複数のトークン埋め込みを1つのベクトルに統合する方法"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b9a0e5fa",
   "metadata": {},
   "source": [
    "## セクション6: 埋め込みベクトル層"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 40,
   "id": "bf41336f",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "完全なパイプライン処理：\n",
      "======================================================================\n",
      "最終ベクトルの形状: (3, 768)\n",
      "\n",
      "最初のテキストの最終ベクトル（最初の10次元）:\n",
      "  平均プーリング: [-1.09279709  0.00737763  0.32400152  0.54715988  0.31523832 -0.54369699\n",
      "  1.12189893 -0.22080991  0.18197756 -0.29186729]\n",
      "  CLSプーリング: [-1.6242471   0.93277353  0.1907262   0.52314234 -0.06636714 -0.13721104\n",
      "  1.0464535  -0.26512212 -0.29776827 -0.20617226]\n"
     ]
    }
   ],
   "source": [
    "class EmbeddingLayer:\n",
    "    \"\"\"埋め込み層の実装\"\"\"\n",
    "    \n",
    "    def __init__(self, vocab_size, embedding_dim=768, device='cpu'):\n",
    "        \"\"\"\n",
    "        Args:\n",
    "            vocab_size: 語彙サイズ\n",
    "            embedding_dim: 埋め込み次元\n",
    "            device: CPU or GPU\n",
    "        \"\"\"\n",
    "        self.embedding_layer = nn.Embedding(vocab_size, embedding_dim)\n",
    "        self.device = device\n",
    "        self.embedding_layer = self.embedding_layer.to(device)\n",
    "    \n",
    "    def forward(self, token_ids):\n",
    "        \"\"\"\n",
    "        トークンIDから埋め込みベクトルを取得\n",
    "        \n",
    "        Args:\n",
    "            token_ids: 形状 (batch_size, seq_length) のテンソル\n",
    "        \n",
    "        Returns:\n",
    "            形状 (batch_size, seq_length, embedding_dim) のテンソル\n",
    "        \"\"\"\n",
    "        if isinstance(token_ids, np.ndarray):\n",
    "            token_ids = torch.from_numpy(token_ids).long().to(self.device)\n",
    "        \n",
    "        embeddings = self.embedding_layer(token_ids)\n",
    "        return embeddings\n",
    "    \n",
    "    def get_embedding_matrix(self):\n",
    "        \"\"\"埋め込み行列全体を取得\"\"\"\n",
    "        return self.embedding_layer.weight.detach().cpu().numpy()\n",
    "\n",
    "\n",
    "class TextToEmbeddingPipeline:\n",
    "    \"\"\"テキスト入力から埋め込みベクトルまでの完全パイプライン\"\"\"\n",
    "    \n",
    "    def __init__(self, vocab, embedding_dim=768, device='cpu'):\n",
    "        self.vocab = vocab\n",
    "        self.embedding_layer = EmbeddingLayer(len(vocab), embedding_dim, device)\n",
    "        self.processor = BatchProcessor(vocab)\n",
    "        self.pooling = SequencePooling()\n",
    "        self.device = device\n",
    "    \n",
    "    def process(self, texts, max_length=None, pooling_method='mean'):\n",
    "        \"\"\"\n",
    "        テキストのリストを埋め込みベクトルに変換\n",
    "        \n",
    "        Args:\n",
    "            texts: トークンのリストのリスト\n",
    "            max_length: パディング最大長\n",
    "            pooling_method: 'mean', 'cls', 'max', 'last'\n",
    "        \n",
    "        Returns:\n",
    "            最終埋め込みベクトル (batch_size, embedding_dim)\n",
    "        \"\"\"\n",
    "        # ステップ1: エンコード + パディング\n",
    "        padded_ids = self.processor.encode_texts(texts, max_length)\n",
    "        attention_mask = self.processor.create_attention_mask(padded_ids)\n",
    "        \n",
    "        # ステップ2: 埋め込み層\n",
    "        embeddings = self.embedding_layer.forward(padded_ids)\n",
    "        embeddings_np = embeddings.detach().cpu().numpy()\n",
    "        \n",
    "        # ステップ3: プーリング\n",
    "        if pooling_method == 'mean':\n",
    "            pooled = self.pooling.mean_pooling(embeddings_np, attention_mask)\n",
    "        elif pooling_method == 'cls':\n",
    "            pooled = self.pooling.cls_pooling(embeddings_np)\n",
    "        elif pooling_method == 'max':\n",
    "            pooled = self.pooling.max_pooling(embeddings_np, attention_mask)\n",
    "        elif pooling_method == 'last':\n",
    "            pooled = self.pooling.last_pooling(embeddings_np, attention_mask)\n",
    "        else:\n",
    "            raise ValueError(f\"Unknown pooling method: {pooling_method}\")\n",
    "        \n",
    "        return pooled\n",
    "\n",
    "# 使用例\n",
    "pipeline = TextToEmbeddingPipeline(vocab, embedding_dim=768)\n",
    "\n",
    "# テキストのトークン化\n",
    "test_texts = [\n",
    "    ['自然', '言語', '処理'],\n",
    "    ['機械', '学習', 'は', '面白い'],\n",
    "    ['深層', '学習', 'は', '強力']\n",
    "]\n",
    "\n",
    "# パイプラインで処理\n",
    "embeddings_mean = pipeline.process(test_texts, pooling_method='mean')\n",
    "embeddings_cls = pipeline.process(test_texts, pooling_method='cls')\n",
    "\n",
    "print(\"完全なパイプライン処理：\")\n",
    "print(\"=\" * 70)\n",
    "print(f\"最終ベクトルの形状: {embeddings_mean.shape}\")\n",
    "print()\n",
    "print(\"最初のテキストの最終ベクトル（最初の10次元）:\")\n",
    "print(f\"  平均プーリング: {embeddings_mean[0, :10]}\")\n",
    "print(f\"  CLSプーリング: {embeddings_cls[0, :10]}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 41,
   "id": "d2b2aa4a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "埋め込み層：\n",
      "======================================================================\n",
      "埋め込みの形状: torch.Size([3, 5, 768])\n",
      "(batch_size=3, seq_length=5, embedding_dim=768)\n",
      "\n",
      "埋め込み行列の形状: (18, 768)\n",
      "(18語彙 × 768次元)\n"
     ]
    }
   ],
   "source": [
    "class EmbeddingLayer:\n",
    "    \"\"\"埋め込み層の実装\"\"\"\n",
    "    \n",
    "    def __init__(self, vocab_size, embedding_dim=768, device='cpu'):\n",
    "        \"\"\"\n",
    "        Args:\n",
    "            vocab_size: 語彙サイズ\n",
    "            embedding_dim: 埋め込み次元\n",
    "            device: CPU or GPU\n",
    "        \"\"\"\n",
    "        self.embedding_layer = nn.Embedding(vocab_size, embedding_dim)\n",
    "        self.device = device\n",
    "        self.embedding_layer = self.embedding_layer.to(device)\n",
    "    \n",
    "    def forward(self, token_ids):\n",
    "        \"\"\"\n",
    "        トークンIDから埋め込みベクトルを取得\n",
    "        \n",
    "        Args:\n",
    "            token_ids: 形状 (batch_size, seq_length) のテンソル\n",
    "        \n",
    "        Returns:\n",
    "            形状 (batch_size, seq_length, embedding_dim) のテンソル\n",
    "        \"\"\"\n",
    "        if isinstance(token_ids, np.ndarray):\n",
    "            token_ids = torch.from_numpy(token_ids).long().to(self.device)\n",
    "        \n",
    "        embeddings = self.embedding_layer(token_ids)\n",
    "        return embeddings\n",
    "    \n",
    "    def get_embedding_matrix(self):\n",
    "        \"\"\"埋め込み行列全体を取得\"\"\"\n",
    "        return self.embedding_layer.weight.detach().cpu().numpy()\n",
    "\n",
    "# 使用例\n",
    "vocab_size = len(vocab)\n",
    "embedding_dim = 768\n",
    "\n",
    "embedding_layer = EmbeddingLayer(vocab_size, embedding_dim, device='cpu')\n",
    "\n",
    "# バッチID\n",
    "batch_ids = padded_ids\n",
    "\n",
    "# 埋め込み取得\n",
    "embeddings = embedding_layer.forward(batch_ids)\n",
    "\n",
    "print(\"埋め込み層：\")\n",
    "print(\"=\" * 70)\n",
    "print(f\"埋め込みの形状: {embeddings.shape}\")\n",
    "print(f\"(batch_size={embeddings.shape[0]}, seq_length={embeddings.shape[1]}, embedding_dim={embeddings.shape[2]})\")\n",
    "print()\n",
    "\n",
    "# 埋め込み行列全体の形状\n",
    "embedding_matrix = embedding_layer.get_embedding_matrix()\n",
    "print(f\"埋め込み行列の形状: {embedding_matrix.shape}\")\n",
    "print(f\"({vocab_size}語彙 × {embedding_dim}次元)\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 36,
   "id": "c42b6c5a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "プーリング結果：\n",
      "======================================================================\n",
      "平均プーリング形状: (3, 768)\n",
      "CLSプーリング形状: (3, 768)\n",
      "最大値プーリング形状: (3, 768)\n",
      "最後プーリング形状: (3, 768)\n"
     ]
    }
   ],
   "source": [
    "class SequencePooling:\n",
    "    \"\"\"複数のシーケンス統合手法\"\"\"\n",
    "    \n",
    "    @staticmethod\n",
    "    def mean_pooling(embeddings, attention_mask):\n",
    "        \"\"\"平均プーリング\"\"\"\n",
    "        mask_expanded = np.expand_dims(attention_mask, axis=-1)\n",
    "        sum_embedding = np.sum(embeddings * mask_expanded, axis=1)\n",
    "        sum_mask = np.sum(mask_expanded, axis=1)\n",
    "        pooled = sum_embedding / np.maximum(sum_mask, 1e-9)\n",
    "        return pooled\n",
    "    \n",
    "    @staticmethod\n",
    "    def cls_pooling(embeddings):\n",
    "        \"\"\"CLS プーリング（最初のトークン）\"\"\"\n",
    "        return embeddings[:, 0, :]\n",
    "    \n",
    "    @staticmethod\n",
    "    def max_pooling(embeddings, attention_mask):\n",
    "        \"\"\"最大値プーリング\"\"\"\n",
    "        embeddings_masked = embeddings.copy()\n",
    "        mask_expanded = np.expand_dims(attention_mask, axis=-1)\n",
    "        embeddings_masked = np.where(\n",
    "            mask_expanded == 1, \n",
    "            embeddings_masked, \n",
    "            -np.inf\n",
    "        )\n",
    "        pooled = np.max(embeddings_masked, axis=1)\n",
    "        return pooled\n",
    "    \n",
    "    @staticmethod\n",
    "    def last_pooling(embeddings, attention_mask):\n",
    "        \"\"\"最後の有効トークンのプーリング\"\"\"\n",
    "        batch_size = embeddings.shape[0]\n",
    "        pooled = np.zeros_like(embeddings[:, 0, :])\n",
    "        \n",
    "        for i in range(batch_size):\n",
    "            last_idx = np.sum(attention_mask[i]) - 1\n",
    "            pooled[i] = embeddings[i, int(last_idx), :]\n",
    "        \n",
    "        return pooled\n",
    "\n",
    "# ============================================================\n",
    "# 埋め込み層の初期化と埋め込み生成\n",
    "# ============================================================\n",
    "\n",
    "# 埋め込み層の初期化\n",
    "vocab_size = len(vocab)\n",
    "embedding_dim = 768\n",
    "\n",
    "embedding_layer = nn.Embedding(vocab_size, embedding_dim)\n",
    "\n",
    "# テスト用のバッチID\n",
    "batch_ids_test = np.array([\n",
    "    padded_ids[0],\n",
    "    padded_ids[1] if len(padded_ids) > 1 else padded_ids[0],\n",
    "    padded_ids[2] if len(padded_ids) > 2 else padded_ids[0]\n",
    "])\n",
    "\n",
    "# テンソルに変換\n",
    "batch_ids_tensor = torch.from_numpy(batch_ids_test).long()\n",
    "\n",
    "# 埋め込み取得\n",
    "embeddings = embedding_layer(batch_ids_tensor)\n",
    "\n",
    "# Attention マスク\n",
    "attention_mask_test = (batch_ids_test != processor.pad_idx).astype(np.int32)\n",
    "\n",
    "# 使用例\n",
    "embeddings_np = embeddings.detach().numpy()\n",
    "\n",
    "pooling = SequencePooling()\n",
    "\n",
    "# 各手法でプーリング実行\n",
    "mean_result = pooling.mean_pooling(embeddings_np, attention_mask_test)\n",
    "cls_result = pooling.cls_pooling(embeddings_np)\n",
    "max_result = pooling.max_pooling(embeddings_np, attention_mask_test)\n",
    "last_result = pooling.last_pooling(embeddings_np, attention_mask_test)\n",
    "\n",
    "print(\"プーリング結果：\")\n",
    "print(\"=\" * 70)\n",
    "print(f\"平均プーリング形状: {mean_result.shape}\")\n",
    "print(f\"CLSプーリング形状: {cls_result.shape}\")\n",
    "print(f\"最大値プーリング形状: {max_result.shape}\")\n",
    "print(f\"最後プーリング形状: {last_result.shape}\")"
   ]
  },
