    "class SimpleRegexTokenizer:\n",
    "    \"\"\"正規表現を使った簡単なトークナイザー\"\"\"\n",
    "    \n",
    "    def tokenize(self, text):\n",
    "        \"\"\"単純な分割（単語と記号を区別）\"\"\"\n",
    "        pattern = r'\\w+|[^\\w\\s]'\n",
    "        tokens = re.findall(pattern, text)\n",
    "        return tokens\n",
    "\n",
    "def demo_end_to_end():\n",
    "    \"\"\"エンドツーエンドデモ\"\"\"\n",
    "    \n",
    "    print(\"【テキスト → トークン化 → 埋め込み完全デモ】\")\n",
    "    print(\"=\" * 80)\n",
    "    print()\n",
    "    \n",
    "    # ステップ1: 入力テキスト\n",
    "    input_texts = [\n",
    "        \"ニューラルネットワークは強力です\",\n",
    "        \"深層学習は機械学習の一部です\",\n",
    "        \"自然言語処理は AI の重要な分野です\"\n",
    "    ]\n",
    "    \n",
    "    print(\"ステップ1: 入力テキスト\")\n",
    "    for i, text in enumerate(input_texts):\n",
    "        print(f\"  {i+1}. {text}\")\n",
    "    print()\n",
    "    \n",
    "    # ステップ2: 正規化\n",
    "    print(\"ステップ2: テキスト正規化\")\n",
    "    normalized = [normalize_text(text) for text in input_texts]\n",
    "    for i, text in enumerate(normalized):\n",
    "        print(f\"  {i+1}. {text}\")\n",
    "    print()\n",
    "    \n",
    "    # ステップ3: トークン化\n",
    "    print(\"ステップ3: トークン化\")\n",
    "    tokenizer = SimpleRegexTokenizer()\n",
    "    tokenized = [tokenizer.tokenize(text) for text in normalized]\n",
    "    for i, tokens in enumerate(tokenized):\n",
    "        print(f\"  {i+1}. {tokens}\")\n",
    "    print()\n",
    "    \n",
    "    # ステップ4: パディング＆エンコード\n",
    "    print(\"ステップ4: パディング＆エンコード\")\n",
    "    proc = BatchProcessor(vocab)\n",
    "    padded = proc.encode_texts(tokenized, max_length=10)\n",
    "    print(f\"  形状: {padded.shape}\")\n",
    "    print()\n",
    "    \n",
    "    # ステップ5: 埋め込み\n",
    "    print(\"ステップ5: 埋め込み層\")\n",
    "    padded_tensor = torch.from_numpy(padded).long()\n",
    "    embeddings = embedding_layer(padded_tensor)\n",
    "    print(f\"  形状: {embeddings.shape}\")\n",
    "    print()\n",
    "    \n",
    "    # ステップ6: プーリング\n",
    "    print(\"ステップ6: シーケンス統合（プーリング）\")\n",
    "    embeddings_np = embeddings.detach().numpy()\n",
    "    attn_mask = proc.create_attention_mask(padded)\n",
    "    final_vectors = pooling.mean_pooling(embeddings_np, attn_mask)\n",
    "    print(f\"  最終形状: {final_vectors.shape}\")\n",
    "    print(f\"  各テキストは {final_vectors.shape[1]} 次元ベクトルに変換\")\n",
    "    print()\n",
    "    \n",
    "    # ステップ7: 類似度計算\n",
    "    print(\"ステップ7: テキスト間の類似度\")\n",
    "    sim_matrix = compute_similarity_matrix(final_vectors)\n",
    "    \n",
    "    for i in range(len(input_texts)):\n",
    "        for j in range(i+1, len(input_texts)):\n",
    "            sim = sim_matrix[i, j]\n",
    "            print(f\"  テキスト{i+1} <-> テキスト{j+1}: {sim:.4f}\")\n",
    "    print()\n",
    "    \n",
    "    print(\"=\" * 80)\n",
    "    print(\"デモ完了！\")\n",
    "\n",
    "# デモを実行\n",
    "demo_end_to_end()"
   ]
