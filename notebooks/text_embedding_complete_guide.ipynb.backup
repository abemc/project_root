    "def compute_similarity_matrix(embeddings):\n",
    "    \"\"\"埋め込みベクトル間のコサイン類似度行列を計算\"\"\"\n",
    "    n = embeddings.shape[0]\n",
    "    similarity_matrix = np.zeros((n, n))\n",
    "    \n",
    "    for i in range(n):\n",
    "        for j in range(n):\n",
    "            if i == j:\n",
    "                similarity_matrix[i, j] = 1.0\n",
    "            else:\n",
    "                similarity_matrix[i, j] = 1 - cosine(embeddings[i], embeddings[j])\n",
    "    \n",
    "    return similarity_matrix\n",
    "\n",
    "# 使用例\n",
    "similarity_matrix = compute_similarity_matrix(mean_result)\n",
    "\n",
    "print(\"埋め込みベクトル間の類似度計算：\")\n",
    "print(\"=\" * 70)\n",
    "print(\"コサイン類似度行列:\")\n",
    "print(similarity_matrix)\n",
    "print()\n",
    "\n",
    "# テキストペアで表示\n",
    "texts_description = [\n",
    "    \"テキスト0: ['自然', '言語', '処理']\",\n",
    "    \"テキスト1: ['機械', '学習', 'は', '面白い']\",\n",
    "    \"テキスト2: ['深層', '学習', 'は', '強力']\"\n",
    "]\n",
    "\n",
    "print(\"テキストペア間の類似度:\")\n",
    "for i in range(len(batch_texts)):\n",
    "    for j in range(i+1, len(batch_texts)):\n",
    "        sim = similarity_matrix[i, j]\n",
    "        print(f\"  {texts_description[i]} <-> {texts_description[j]}: {sim:.4f}\")\n",
    "print()\n",
    "\n",
    "# 類似度の可視化\n",
    "fig, ax = plt.subplots(figsize=(6, 5))\n",
    "im = ax.imshow(similarity_matrix, cmap='coolwarm', aspect='auto', vmin=-1, vmax=1)\n",
    "\n",
    "ax.set_xticks(range(len(batch_texts)))\n",
    "ax.set_yticks(range(len(batch_texts)))\n",
    "ax.set_xticklabels([f'Text {i}' for i in range(len(batch_texts))])\n",
    "ax.set_yticklabels([f'Text {i}' for i in range(len(batch_texts))])\n",
    "ax.set_title('Text Embedding Similarity Matrix', fontsize=12, fontweight='bold')\n",
    "\n",
    "# 値をテキストで表示\n",
    "for i in range(len(batch_texts)):\n",
    "    for j in range(len(batch_texts)):\n",
    "        text = ax.text(j, i, f'{similarity_matrix[i, j]:.2f}',\n",
    "                      ha=\"center\", va=\"center\", color=\"black\", fontsize=11)\n",
    "\n",
    "plt.colorbar(im, ax=ax, label='Similarity')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"✓ 類似度マトリックスの可視化完了\")"
   ]
  },
