    "import pandas as pd\n",
    "\n",
    "# プーリング方法の比較表\n",
    "comparison_data = {\n",
    "    'プーリング方法': ['平均プーリング', 'CLSプーリング', '最大値プーリング', '最後プーリング'],\n",
    "    '説明': [\n",
    "        'すべてのトークンの平均（パディング除外）',\n",
    "        '最初のトークンのみを使用（BERT標準）',\n",
    "        '各次元の最大値を抽出',\n",
    "        '最後の有効トークンを使用'\n",
    "    ],\n",
    "    '利点': [\n",
    "        'ノイズに強い、全情報を保持',\n",
    "        '学習済みモデル対応、安定',\n",
    "        '重要な特徴を抽出',\n",
    "        'コンテキスト情報充実'\n",
    "    ],\n",
    "    '推奨度': ['★★★★', '★★★★★', '★★★', '★★']\n",
    "}\n",
    "\n",
    "df_comparison = pd.DataFrame(comparison_data)\n",
    "\n",
    "print(\"プーリング方法の比較：\")\n",
    "print(\"=\" * 100)\n",
    "print(df_comparison.to_string(index=False))\n",
    "print()\n",
    "\n",
    "print(\"推奨される選択:\")\n",
    "print(\"- 開発フェーズ: CLSプーリング（BERT標準）\")\n",
    "print(\"- 検証フェーズ: 平均プーリングと比較\")\n",
    "print(\"- 本番環境: タスクに応じて選択（精度を優先なら平均）\")"
   ]
  }
