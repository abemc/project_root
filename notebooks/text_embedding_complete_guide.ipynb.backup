   "source": [
    "class SimpleRegexTokenizer:\n",
    "    \"\"\"正規表現を使った簡単なトークナイザー\"\"\"\n",
    "    \n",
    "    def tokenize(self, text):\n",
    "        \"\"\"\n",
    "        単純な分割（単語と記号を区別）\n",
    "        \"\"\"\n",
    "        # 単語（連続する英数字）と記号を分割\n",
    "        pattern = r'\\w+|[^\\w\\s]'\n",
    "        tokens = re.findall(pattern, text)\n",
    "        return tokens\n",
    "\n",
    "# 使用例\n",
    "tokenizer = SimpleRegexTokenizer()\n",
    "\n",
    "texts = [\n",
    "    \"I love Natural Language Processing!\",\n",
    "    \"自然言語処理は難しい。\",\n",
    "    \"Python3.11は高速だ。\"\n",
    "]\n",
    "\n",
    "print(\"トークン化の例：\")\n",
    "print(\"=\" * 70)\n",
    "\n",
    "for text in texts:\n",
    "    tokens = tokenizer.tokenize(text)\n",
    "    print(f\"入力: {text}\")\n",
    "    print(f\"トークン: {tokens}\")\n",
    "    print()"
   ]
