{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Enterprise Security Platform - 7層セキュリティアーキテクチャ監視",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": 1001,
  "links": [
    {
      "icon": "doc",
      "includeVars": false,
      "keepTime": true,
      "tags": ["security", "platform"],
      "targetBlank": true,
      "title": "Technical Documentation",
      "url": "https://docs.security-platform.com/architecture"
    },
    {
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": ["alerts"],
      "targetBlank": true,
      "title": "Alert Manager",
      "url": "http://alertmanager:9093"
    }
  ],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"axisLabel": "", "axisPlacement": "auto"},
          "mappings": [],
          "thresholds": {
            "mode": "percentage",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 95},
              {"color": "green", "value": 99}
            ]
          }
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 2,
      "options": {"orientation": "auto", "reduceOptions": {"values": false, "fields": ""}, "showThresholdLabels": false, "showThresholdMarkers": true},
      "pluginVersion": "8.0.0",
      "targets": [
        {
          "expr": "auth_success_rate",
          "refId": "A"
        }
      ],
      "title": "Layer 1: Authentication - Success Rate",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 3,
      "options": {
        "legend": {"calcs": ["last", "mean"], "displayMode": "list", "placement": "bottom"}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, auth_latency_seconds)",
          "legendFormat": "Auth Latency (P99)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, mfa_verification_duration_seconds)",
          "legendFormat": "MFA Duration (P95)",
          "refId": "B"
        }
      ],
      "title": "Layer 1: Authentication Latency",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 4,
      "options": {
        "legend": {"calcs": ["last", "mean"], "displayMode": "list", "placement": "bottom"}
      },
      "targets": [
        {
          "expr": "rate(encryption_operations_total[5m])",
          "legendFormat": "Encryption Rate",
          "refId": "A"
        },
        {
          "expr": "rate(encryption_errors_total[5m])",
          "legendFormat": "Error Rate",
          "refId": "B"
        }
      ],
      "title": "Layer 2: Encryption Operations",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 5,
      "options": {},
      "targets": [
        {
          "expr": "count(zerotrust_policy_violations_total > 0)",
          "legendFormat": "Policy Violations",
          "refId": "A"
        }
      ],
      "title": "Layer 3: Zero Trust Policy Violations",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": {"hideFrom": {"legend": false, "tooltip": false, "viz": false}},
          "mappings": []
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 6,
      "options": {"displayLabels": ["name", "value"], "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "expr": "soc_event_queue_length",
          "legendFormat": "Queue Length",
          "refId": "A"
        }
      ],
      "title": "Layer 4: SOC Event Queue Status",
      "type": "piechart"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "id": 7,
      "options": {
        "legend": {"calcs": ["last"], "displayMode": "list", "placement": "bottom"}
      },
      "targets": [
        {
          "expr": "threat_detection_latency_seconds",
          "legendFormat": "Detection Latency",
          "refId": "A"
        }
      ],
      "title": "Layer 5: ML Threat Detection Latency",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
      "id": 8,
      "options": {
        "showLegend": true
      },
      "targets": [
        {
          "expr": "compliance_violation_count",
          "legendFormat": "Compliance Violations",
          "refId": "A"
        }
      ],
      "title": "Layer 6: Compliance Status",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "id": 9,
      "options": {
        "legend": {"calcs": ["last", "mean"], "displayMode": "list", "placement": "bottom"}
      },
      "targets": [
        {
          "expr": "sla_achievement",
          "legendFormat": "SLA Achievement",
          "refId": "A"
        }
      ],
      "title": "Layer 7: Global SLA Achievement",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "id": 10,
      "options": {
        "legend": {"calcs": ["last"], "displayMode": "list", "placement": "bottom"}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, interregion_latency_seconds)",
          "legendFormat": "Inter-region Latency (P95)",
          "refId": "A"
        }
      ],
      "title": "Layer 7: Global Replication Status",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 27,
  "style": "dark",
  "tags": ["security", "enterprise", "7layer", "monitoring"],
