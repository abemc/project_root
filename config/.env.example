# Python パス設定
PYTHONPATH=src

# ============================================================
# バックアップ設定 - 外部ドライブ指定（オプション）
# ============================================================

# バックアップを外部ドライブに保存する場合、下記を設定してください
# （環境に応じて適切なパスに変更してください）

# Linux / WSL の場合
# BACKUP_ROOT=/mnt/external_drive/backups

# Windows (WSL 経由で D: ドライブを指定) の場合
# BACKUP_ROOT=/mnt/d/backups

# macOS の場合（外部ドライブ /Volumes/External をマウント）
# BACKUP_ROOT=/Volumes/External/project_backups

# Windows (ネイティブ) の場合
# BACKUP_ROOT=D:\\project_backups

# ============================================================
# 使用方法
# ============================================================
# 1. このファイルを .env にコピー
#    cp .env.example .env
#
# 2. BACKUP_ROOT 行をアンコメント + パス編集
#
# 3. 以下のコマンドでバックアップ作成
#    python tools/backup_cli.py create --compress
#
# または、コマンドラインで直接指定：
#    python tools/backup_cli.py --external-drive /mnt/external create --compress
#    python tools/backup_cli.py --drive D: create --compress  # Windows WSL
# ============================================================
